
<QuizAnswerMulti>:
    canvas:
        Color:
            rgba: 0.4, 0.5, 0.65, 1.0
        Rectangle:
            pos: self.posX-(self.sizeX/2), self.posY-(self.sizeY/2)
            size: self.sizeX, self.sizeY


<questionInstance>:
    canvas:
        Color:
            rgba: 111/255,189/255,249/255,1
        Rectangle:
            pos: self.posX-(self.sizeX/2), self.posY-(self.sizeY/2)
            size: self.sizeX, self.sizeY
<quizinstance>:
    canvas:
        Color:
            rgba:  111/255,189/255,249/255,1
        Rectangle:
            pos: self.posX-(self.sizeX/2), self.posY-(self.sizeY/2)
            size: self.sizeX, self.sizeY
<QuestionEdit>:
    canvas:
        Color:
            rgba: 111/255,189/255,249/255,1
        Rectangle:
            pos: self.posX-(self.sizeX/2), self.posY-(self.sizeY/2)
            size: self.sizeX, self.sizeY
<ScrollView>:
    canvas:
        Color:
            rgba: 0.8, 0.8, 0.8, 1
        Rectangle:
            pos: self.center_x-self.width/2, self.center_y-self.height/2
            size: self.width, self.height

<appManager>:
    canvas:
        Color:
            rgba: 1, 1, 1, 1.0
        Rectangle:
            pos: self.center_x-self.width/2, self.center_y-self.height/2
            size: self.width, self.height

<ImageButton>:
    Image:
        id: buttonImage
        source:  'Images/house.png'
        size: self.parent.size
        center_x: self.parent.center_x
        center_y: self.parent.center_y









